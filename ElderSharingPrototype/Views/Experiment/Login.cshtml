@model ElderSharingPrototype.Models.LoginViewModel

@{
    ViewData["Title"] = "כניסה לניסוי";
}

<div class="container-fluid min-vh-100 d-flex justify-content-center"
     style="padding-top: 100px;">

    <div class="card shadow-lg"
         style="
            max-width: 420px;
            width: 100%;
            padding: 36px;
            align-self: flex-start;
         ">

        <div class="text-center mb-4">
            <h1 style="font-size:40px; font-weight:700;">
                כניסה לניסוי
            </h1>

            <!-- ✅ טקסט הנחיה ברור ופשוט -->
            <p class="mt-3"
               style="font-size:22px; font-weight:500;">
                אנא הזן/י את מספר הזיהוי שקיבלת
            </p>
        </div>

        <form asp-action="Login" method="post">

            <div class="mb-4">
                <label asp-for="SerialNumber"
                       class="form-label text-center w-100"
                       style="font-size:20px;">
                    מספר זיהוי
                </label>

                <input asp-for="SerialNumber"
                       class="form-control form-control-lg text-center"
                       style="font-size:22px;" />

                <span asp-validation-for="SerialNumber"
                      class="text-danger d-block text-center mt-2"
                      style="font-size:18px;"></span>
            </div>

            <div class="d-grid">
                <button type="submit"
                        class="btn btn-primary btn-lg"
                        style="font-size:24px; padding:14px;">
                    המשך
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
