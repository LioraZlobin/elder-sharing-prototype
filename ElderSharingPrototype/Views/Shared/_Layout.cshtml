@using ElderSharingPrototype.Models
@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElderSharingPrototype</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ElderSharingPrototype.styles.css" asp-append-version="true" />
</head>

@{
        // UiAdaptation נשמר ב-Session
        var ui = Context.Session.GetInt32("UiAdaptation") ?? (int)UiAdaptation.NotAdapted;
        bool isAdapted = ui == (int)UiAdaptation.Adapted;

        var isLoggedIn = Context.Session.GetString("IsLoggedIn") == "true";
        var firstName = Context.Session.GetString("FirstName") ?? "";

        // ✅ חשוב: זה מה שמפעיל את כל ה-CSS של body.ui-adapted גם בדפי Health
        var bodyClass = isAdapted ? "ui-adapted medical-bg" : "ui-plain";

        // (רשות) שהדיסקליימר העליון יגדל יחד עם הממשק
        var disclaimerStyle = isAdapted
                ? "font-size: 32px; line-height: 1.8;"
                : "font-size: 18px;";
}

<body class="@bodyClass">

    <!-- ✅ Wrapper חדש בשביל Sticky Footer -->
    <div class="page-wrapper">

        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                        ElderSharingPrototype
                    </a>

                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target=".navbar-collapse"
                            aria-controls="navbarSupportedContent"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav me-auto">
                            @if (isLoggedIn)
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-muted">
                                        שלום, <strong>@firstName</strong>
                                    </span>

                                    <form method="post" action="/Prototype/Logout" class="m-0">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            התנתקות
                                        </button>
                                    </form>
                                </div>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <!-- ✅ main מקבל flex:1 דרך CSS -->
        <main role="main" class="content pb-3">
            <div class="container">
                <div class="alert alert-light border text-center mb-3" style="@disclaimerStyle">
                    איננו שומרים מידע מעבר לנדרש.
                </div>

                @RenderBody()
            </div>
        </main>

        <!-- ✅ footer תמיד בתחתית -->
        <footer class="border-top footer text-muted">
            <div class="container text-center">
                &copy; 2025 - ElderSharingPrototype -
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>

    </div>

    <!-- ✅ Reminder Modal (global) -->
    <div class="modal fade" id="reminderModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:18px;">
                <div class="modal-header">
                    <h5 class="modal-title" id="reminderTitle">⏰ תזכורת</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="סגור"></button>
                </div>
                <div class="modal-body">
                    <div id="reminderBody" style="font-size:18px; line-height:1.6; white-space:pre-line;"></div>
                    <div class="text-muted mt-2" style="font-size:14px;">
                        (דמו) התזכורת מופיעה כל עוד האתר פתוח.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-bs-dismiss="modal">הבנתי ✅</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- ✅ Global Reminder Checker (NO refresh needed) -->
    <script>
        (function () {
            const isLoggedIn = "@(isLoggedIn ? "true" : "false")";
            if (isLoggedIn !== "true") return;

            const MODAL_ID = "reminderModal";
            const STORAGE_KEY = "lastReminderShownAt"; // נשמור "yyyy-MM-dd HH:mm" כדי לא להקפיץ פעמיים באותה דקה
            let isChecking = false;

            function getNowMinuteKey() {
                const d = new Date();
                const pad = (n) => (n < 10 ? "0" + n : "" + n);
                return d.getFullYear() + "-" + pad(d.getMonth() + 1) + "-" + pad(d.getDate()) +
                    " " + pad(d.getHours()) + ":" + pad(d.getMinutes());
            }

            function alreadyShownThisMinute() {
                try {
                    const key = localStorage.getItem(STORAGE_KEY) || "";
                    return key === getNowMinuteKey();
                } catch (e) {
                    return false;
                }
            }

            function markShownThisMinute() {
                try {
                    localStorage.setItem(STORAGE_KEY, getNowMinuteKey());
                } catch (e) { }
            }

            async function checkReminders(force = false) {
                if (isChecking) return;
                if (!force && alreadyShownThisMinute()) return;

                isChecking = true;

                try {
                    const resp = await fetch("/Health/DueReminders", {
                        method: "GET",
                        cache: "no-store",
                        headers: { "X-Requested-With": "fetch" }
                    });

                    const data = await resp.json();
                    if (!data || !data.ok) return;
                    if (!data.due || data.due.length === 0) return;

                    if (!force) markShownThisMinute();

                    const lines = data.due.map(x => {
                        let extra = "";
                        if (x.type === "Medication" && x.medicationName) extra = " (" + x.medicationName + ")";
                        if (x.notes) extra += " — " + x.notes;
                        return "• " + x.title + extra;
                    });

                    const titleEl = document.getElementById("reminderTitle");
                    const bodyEl = document.getElementById("reminderBody");

                    if (!titleEl || !bodyEl) return;

                    titleEl.innerText = "⏰ תזכורת (" + (data.now || "") + ")";
                    bodyEl.innerText = "הגיע הזמן לבצע:\n" + lines.join("\n");

                    try {
                        window.speechSynthesis.cancel();
                        const u = new SpeechSynthesisUtterance("הגיעה תזכורת. אנא בדקי את ההודעה על המסך.");
                        u.lang = "he-IL";
                        window.speechSynthesis.speak(u);
                    } catch (e) { }

                    const modalEl = document.getElementById(MODAL_ID);
                    if (!modalEl) return;

                    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.show();

                } catch (e) {
                    // שקט
                } finally {
                    isChecking = false;
                }
            }

            function scheduleAligned() {
                const now = new Date();
                const msToNextMinute =
                    (60 - now.getSeconds()) * 1000 - now.getMilliseconds();

                setTimeout(() => {
                    checkReminders(true);
                    setInterval(() => checkReminders(true), 60 * 1000);
                }, msToNextMinute);
            }

            checkReminders(true);
            scheduleAligned();

            document.addEventListener("visibilitychange", function () {
                if (document.visibilityState === "visible") {
                    checkReminders(true);
                }
            });

        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
