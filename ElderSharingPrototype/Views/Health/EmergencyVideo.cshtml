@model ElderSharingPrototype.Models.Health.EmergencyVideoViewModel

@{
    ViewData["Title"] = "שיחת חירום - וידאו";
}

<div class="container py-4" style="max-width: 900px;">
    <h1 class="mb-3">שיחת חירום – וידאו</h1>

    <div class="alert alert-info">
        כאן ניתן להציג דמו של שיחת וידאו/הכנה לשיחת וידאו (אב־טיפוס).
    </div>

    <form asp-action="EmergencyVideo" method="post" class="card p-3 shadow-sm">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" rows="3" class="form-control"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-success" onclick="startEmergencyDemo()">התחל דמו</button>
                    <button type="button" class="btn btn-outline-danger" onclick="stopEmergencyDemo()">עצור דמו</button>
                </div>

                <div id="emergencyDemoArea" class="mt-3" style="display:none;">
                    <div class="border rounded p-3">
                        <strong>דמו וידאו (מצלמה+מיקרופון):</strong>

                        <div class="mt-3">
                            <video id="emergencyLocalVideo"
                                   autoplay playsinline muted
                                   style="width:100%; max-height:380px; border-radius:12px; background:#000;">
                            </video>
                        </div>

                        <small class="text-muted d-block mt-2">
                            זהו דמו מקומי – מציג את המצלמה שלך. אין שידור אמיתי לצד שני.
                        </small>
                    </div>
                </div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">שמירה</button>
                <a class="btn btn-outline-secondary" href="/Prototype/Services">חזרה לשירותים</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let emergencyStream = null;

        async function startEmergencyDemo() {
            document.getElementById('emergencyDemoArea').style.display = 'block';

            try {
                emergencyStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
                const video = document.getElementById('emergencyLocalVideo');
                video.srcObject = emergencyStream;
                await video.play();
            } catch (err) {
                console.error(err);
                alert("לא הצלחנו להפעיל מצלמה/מיקרופון. בדקי הרשאות בדפדפן (Allow).");
            }
        }

        function stopEmergencyDemo() {
            if (emergencyStream) {
                emergencyStream.getTracks().forEach(t => t.stop());
                emergencyStream = null;
            }
            const video = document.getElementById('emergencyLocalVideo');
            video.srcObject = null;
            document.getElementById('emergencyDemoArea').style.display = 'none';
        }
    </script>
}
