@using ElderSharingPrototype.Models
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "התראה קולית (דמו)";

    // ✅ קריאה מה-Session
    var ui = Context.Session.GetInt32("UiAdaptation") ?? (int)UiAdaptation.NotAdapted;
    bool isAdapted = ui == (int)UiAdaptation.Adapted;

    // ✅ אותם גדלים כמו בדף ההמלצות (הגרסה המאוזנת)
    var titleStyle = isAdapted
        ? "font-size:56px !important; line-height:1.25 !important; font-weight:800 !important;"
        : "font-size:32px; line-height:1.3; font-weight:700;";

    var alertStyle = isAdapted
        ? "font-size:28px !important; line-height:1.75 !important; padding:20px 22px !important;"
        : "font-size:18px; line-height:1.6;";

    var cardStyle = isAdapted
        ? "font-size:28px !important; line-height:1.85 !important; padding:24px 26px !important;"
        : "font-size:18px; line-height:1.6;";

    var h2Style = isAdapted
        ? "font-size:32px !important; font-weight:800 !important;"
        : "";

    var liStyle = isAdapted
        ? "margin-bottom:14px !important;"
        : "margin-bottom:8px;";

    var statusStyle = isAdapted
        ? "font-size:28px !important; line-height:1.75 !important;"
        : "font-size:18px; line-height:1.6;";

    var mutedStyle = isAdapted
        ? "font-size:20px !important; line-height:1.7 !important;"
        : "font-size:14px; line-height:1.5;";

    var backLinkStyle = isAdapted
        ? "font-size:24px !important; font-weight:700 !important;"
        : "";
}

<div class="container py-4" style="max-width: 900px;">

    <h1 class="mb-3" style="@titleStyle">התראה קולית (דמו)</h1>

    <div class="alert alert-info" style="@alertStyle">
        זהו דמו. אין כאן חיבור לחיישנים אמיתיים.
    </div>

    <div class="card" style="@cardStyle">
        <h2 class="h5 mb-3" style="@h2Style">דוגמה להתראות:</h2>

        <ul class="mb-3">
            <li style="@liStyle">חריגה במדד (למשל לחץ דם גבוה).</li>
            <li style="@liStyle">סיכון סביבתי (למשל חום קיצוני).</li>
        </ul>

        <!-- ✅ קישור לקובץ שהוספת ב-wwwroot/Sounds -->
        <audio id="alertSound" preload="auto">
            <source src="/Sounds/alert-444816.mp3" type="audio/mpeg" />
            הדפדפן לא תומך בהשמעת שמע.
        </audio>

        <div class="d-flex flex-wrap gap-2 mt-2">
            <button type="button" class="btn btn-outline-secondary btn-lg" onclick="unlockAudio()">
                פתיחת קול (אם לא עובד)
            </button>

            <button type="button" class="btn btn-primary btn-lg" onclick="playAlert()">
                הפעל התרעה קולית
            </button>
        </div>

        <div id="statusBox" class="alert alert-warning mt-3" style="display:none; @statusStyle"></div>

        <div class="text-muted mt-2" style="@mutedStyle">
            אם לא נשמע קול: ודאי שהדפדפן לא על Mute, נסי Chrome/Edge, ולחצי קודם על "פתיחת קול".
        </div>
    </div>

    <div class="mt-4">
        <a class="btn btn-link" href="/Prototype/Services" style="@backLinkStyle">חזרה לשירותים</a>
    </div>
</div>

@section Scripts {
    <script>
        function setStatus(msg) {
            const box = document.getElementById('statusBox');
            box.style.display = 'block';
            box.innerText = msg;
        }

        // לפעמים בדפדפנים צריך "אינטראקציה" כדי לאפשר אודיו
        function unlockAudio() {
            try {
                const AudioCtx = window.AudioContext || window.webkitAudioContext;
                if (!AudioCtx) {
                    setStatus("הדפדפן לא תומך ב-AudioContext. נסי Chrome/Edge.");
                    return;
                }

                const ctx = new AudioCtx();
                const o = ctx.createOscillator();
                const g = ctx.createGain();

                g.gain.value = 0.0001; // כמעט שקט
                o.connect(g);
                g.connect(ctx.destination);

                o.start(0);
                o.stop(ctx.currentTime + 0.05);

                setStatus("בוצעה 'פתיחת קול'. עכשיו נסי שוב 'הפעל התרעה קולית'.");
            } catch (e) {
                console.error(e);
                setStatus("לא הצלחנו לבצע פתיחת קול. נסי דפדפן אחר (Chrome/Edge).");
            }
        }

        // ---- 1) קודם ננסה לנגן MP3 ----
        async function playMp3() {
            const audio = document.getElementById("alertSound");
            if (!audio) return false;

            try {
                audio.currentTime = 0;
                await audio.play();
                return true;
            } catch (e) {
                console.error("MP3 play failed:", e);
                return false;
            }
        }

        // ---- 2) אם MP3 נכשל, ננסה SpeechSynthesis ----
        function getHebrewVoice() {
            const voices = window.speechSynthesis.getVoices() || [];
            return voices.find(v => (v.lang || "").toLowerCase().startsWith("he"))
                || voices.find(v => (v.name || "").toLowerCase().includes("hebrew"))
                || null;
        }

        function speakNow() {
            const msg = "שימו לב. זוהתה חריגה במדדים. אם אינך מרגישה טוב, מומלץ לפנות לגורם רפואי.";

            const u = new SpeechSynthesisUtterance(msg);
            u.lang = "he-IL";
            u.rate = 1.0;
            u.pitch = 1.0;
            u.volume = 1.0;

            const heVoice = getHebrewVoice();
            if (heVoice) u.voice = heVoice;

            u.onstart = () => setStatus("מפעיל התרעה קולית (דיבור)...");
            u.onend = () => setStatus("התרעה קולית הסתיימה.");
            u.onerror = (e) => {
                console.error(e);
                setStatus("הייתה שגיאה בהשמעת הדיבור. נסי Chrome/Edge ולחצי קודם 'פתיחת קול'.");
            };

            window.speechSynthesis.cancel();
            try { window.speechSynthesis.resume(); } catch { }

            window.speechSynthesis.speak(u);
        }

        function playSpeechFallback() {
            if (!window.speechSynthesis) {
                setStatus("אין תמיכה בדיבור בדפדפן הזה. נסי Chrome/Edge.");
                return;
            }

            const voices = window.speechSynthesis.getVoices();
            if (!voices || voices.length === 0) {
                setStatus("טוען קולות... נסי שוב עוד רגע.");
                window.speechSynthesis.onvoiceschanged = () => {
                    window.speechSynthesis.onvoiceschanged = null;
                    speakNow();
                };
                return;
            }

            speakNow();
        }

        // ---- כפתור ראשי: MP3 ואז גיבוי ----
        async function playAlert() {
            setStatus("מנסה לנגן קובץ התרעה...");
            const ok = await playMp3();

            if (ok) {
                setStatus("התרעה הושמעה (MP3).");
                return;
            }

            setStatus("לא הצלחנו לנגן MP3. עוברים לדיבור...");
            playSpeechFallback();
        }
    </script>
}
