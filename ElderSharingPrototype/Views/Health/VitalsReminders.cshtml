@model List<ElderSharingPrototype.Models.Health.ReminderItem>
@{
    ViewData["Title"] = "תזכורות מדדים";
}

<div class="container py-4" style="max-width: 900px;">
    <h1 class="mb-3">תזכורות מדדים</h1>
    <div class="alert alert-info" style="font-size:18px;">איננו שומרים מידע מעבר לנדרש. הנתונים נשארים במכשיר.</div>

    <form method="post" action="/Health/AddVitalsReminder" class="card p-3 mb-4">
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label" style="font-size:18px;">איזה מדד?</label>
                <select name="vitalType" class="form-select form-select-lg">
                    <option value="">בחר/י</option>
                    <option value="לחץ דם">לחץ דם</option>
                    <option value="סוכר">סוכר</option>
                </select>
                <span class="text-danger">@Html.ValidationMessage("vitalType")</span>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label" style="font-size:18px;">שעה</label>
                <input name="time" type="time" class="form-control form-control-lg" />
                <span class="text-danger">@Html.ValidationMessage("time")</span>
            </div>
        </div>
        <button class="btn btn-primary btn-lg mt-3" type="submit">הוסף תזכורת</button>
    </form>

    <h2 class="h4 mb-2">הרשימה שלי</h2>
    @if (!Model.Any())
    {
        <div class="text-muted" style="font-size:18px;">אין עדיין תזכורות.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var r in Model)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div style="font-size:18px;">
                        <strong>@r.Title</strong> — @r.Time
                    </div>
                    <form method="post" action="/Health/DeleteVitalsReminder" class="m-0">
                        <input type="hidden" name="id" value="@r.Id" />
                        <button class="btn btn-outline-danger">מחק</button>
                    </form>
                </div>
            }
        </div>
    }

    <div class="mt-4">
        <a class="btn btn-link" href="/Prototype/Services">חזרה לשירותים</a>
    </div>
</div>
