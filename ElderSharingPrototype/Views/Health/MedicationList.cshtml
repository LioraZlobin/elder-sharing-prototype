@model List<string>
@{
    ViewData["Title"] = "ניהול רשימת תרופות קבועות";
    var catalog = ViewBag.MedCatalog as List<string> ?? new List<string>();
}

<div class="container py-4" style="max-width: 900px;">
    <h1 class="mb-3">ניהול רשימת תרופות קבועות</h1>

    <div class="alert alert-info" style="font-size:18px;">
        איננו שומרים מידע מעבר לנדרש. הנתונים נשארים במכשיר.
    </div>

    @if (TempData["MedListError"] != null)
    {
        <div class="alert alert-danger" style="font-size:18px;">
            @TempData["MedListError"]
        </div>
    }

    <div class="card p-3 mb-4">
        <h2 class="h5 mb-3">הוספת תרופה לרשימה</h2>

        <form method="post" action="/Health/AddMedicationToList" class="row g-2">
            <div class="col-12 col-md-8">
                <label class="form-label" style="font-size:18px;">בחרי תרופה מהקטלוג</label>

                <select name="name"
                        class="form-select form-select-lg"
                        id="medCatalogSelect">
                    <option></option>
                    @foreach (var m in catalog)
                    {
                        <option value="@m">@m</option>
                    }
                </select>

                <div class="form-text" style="font-size:16px;">
                    התחילי להקליד (למשל: א → אק → אקמול) כדי לצמצם את הרשימה.
                </div>
            </div>

            <div class="col-12 col-md-4 d-flex align-items-end">
                <button class="btn btn-primary btn-lg w-100" type="submit">הוסף</button>
            </div>
        </form>
    </div>

    <h2 class="h4 mb-2">הרשימה שלי</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-muted" style="font-size:18px;">אין עדיין תרופות שמורות ברשימה שלך.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var med in Model.OrderBy(x => x))
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div style="font-size:18px;">
                        <strong>@med</strong>
                    </div>

                    <form method="post" action="/Health/RemoveMedicationFromList" class="m-0">
                        <input type="hidden" name="name" value="@med" />
                        <button class="btn btn-outline-danger">מחק</button>
                    </form>
                </div>
            }
        </div>
    }

    <div class="mt-4">
        <a class="btn btn-link" href="/Prototype/Services">חזרה לשירותים</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- Select2 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#medCatalogSelect').select2({
                placeholder: "בחר/י תרופה מהרשימה",
                width: '100%',
                dir: "rtl"
            });
        });
    </script>
}
