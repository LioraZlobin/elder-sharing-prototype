@{
    ViewData["Title"] = "בחירת רמת שיתוף";
}

<div class="container py-4" style="max-width: 1000px;">
    <h1 class="mb-3">בחירת רמת שיתוף</h1>
    <p class="text-muted mb-4">בחרו את הרמה שמתאימה לכם. אפשר לשנות בכל רגע.</p>

    <div class="row g-3">

        <!-- רמה A -->
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">רמה 1 – פרטיות גבוהה</h2>
                    <p class="text-muted">מינימום שיתוף, שימוש בסיסי בלבד.</p>
                    <ul>
                        <li>חדשות, תזכורות כלליות, מזג אוויר</li>
                        <li>ללא מידע רפואי/בנקאי</li>
                        <li>ללא קול/מצלמה</li>
                    </ul>

                    <form method="post" class="mt-auto">
                        <input type="hidden" name="level" value="A" />
                        <button type="submit" class="btn btn-outline-primary w-100 btn-lg">
                            בחר רמה זו
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- רמה B -->
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">רמה 2 – שיתוף בינוני</h2>
                    <p class="text-muted">נוחות בשירותים רפואיים בסיסיים.</p>
                    <ul>
                        <li>תזכורות תרופות ותורים</li>
                        <li>ללא צילום וללא שמירת קול</li>
                        <li>אפשר לשנות בכל רגע</li>
                    </ul>

                    <form method="post" class="mt-auto">
                        <input type="hidden" name="level" value="B" />
                        <button type="submit" class="btn btn-outline-primary w-100 btn-lg">
                            בחר רמה זו
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- רמה C -->
        <div class="col-12 col-md-4">
            <div class="card h-100 border-primary">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">רמה 3 – שיתוף גבוה</h2>
                    <p class="text-muted">שירותים מלאים (דמו) למי שמעוניין.</p>
                    <ul>
                        <li>בנק (קריאה בלבד): יתרה ותנועות</li>
                        <li>קופת חולים: מסמכים ותורים</li>
                        <li>אפשרות שירות מצוקה</li>
                    </ul>

                    <form method="post" class="mt-auto">
                        <input type="hidden" name="level" value="C" />
                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            בחר רמה זו
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-4">
        <a class="btn btn-link" href="/Prototype/Intro">חזרה למסך הסבר</a>
    </div>
</div>
