@{
    ViewData["Title"] = "בחירת רמת שיתוף";
}

<div class="container py-4" style="max-width: 1000px;">
    <h1 class="mb-3">בחירת רמת שיתוף</h1>
    <p class="text-muted mb-4" style="font-size:18px;">בחרו את הרמה שמתאימה לכם. אפשר לשנות בכל רגע.</p>

    <div class="row g-3">

        <!-- רמה 1 -->
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column" style="font-size:18px;">
                    <h2 class="h5">רמה 1 – פרטיות גבוהה</h2>
                    <p class="text-muted">מתאים למי שרוצה להתחיל בזהירות</p>
                    <ul>
                        <li>תזכורות כלליות לתרופות ולמדדים</li>
                        <li>לא נדרש להזין מידע רפואי אישי</li>
                        <li>אין חיבור לקופת חולים</li>
                        <li>אפשר לעבור רמה בכל רגע</li>
                    </ul>

                    <form method="post" class="mt-auto">
                        <input type="hidden" name="level" value="A" />
                        <button type="submit" class="btn btn-outline-primary w-100 btn-lg">
                            בחר רמה זו
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- רמה 2 -->
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column" style="font-size:18px;">
                    <h2 class="h5">רמה 2 – שיתוף בינוני</h2>
                    <p class="text-muted">עזרה יומיומית, בלי לוותר על פרטיות</p>
                    <ul>
                        <li>תזכורות עם שם תרופה</li>
                        <li>ניהול רשימת תרופות קבועות</li>
                        <li>המידע נשאר במכשיר בלבד</li>
                        <li>אפשר למחוק מידע בכל רגע</li>
                    </ul>

                    <form method="post" class="mt-auto">
                        <input type="hidden" name="level" value="B" />
                        <button type="submit" class="btn btn-outline-primary w-100 btn-lg">
                            בחר רמה זו
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- רמה 3 -->
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column" style="font-size:18px;">
                    <h2 class="h5">רמה 3 – שיתוף גבוה</h2>
                    <p class="text-muted">למי שמעוניין במעקב רפואי מלא</p>
                    <ul>
                        <li>הזנת מדידות: לחץ דם וסוכר</li>
                        <li>זימון תור לרופא (בדמו)</li>
                        <li>זיהוי לצורך שירותים מתקדמים בלבד</li>
                        <li>אפשר להוריד רמת שיתוף בכל רגע</li>
                    </ul>

                    <form method="post" class="mt-auto">
                        <input type="hidden" name="level" value="C" />
                        <button type="submit" class="btn btn-outline-primary w-100 btn-lg">
                            בחר רמה זו
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>


    </div>

    <div class="mt-4 d-grid gap-2">
        <a class="btn btn-link" href="/Prototype/Intro" style="font-size:18px;">חזרה למסך הסבר</a>
    </div>
</div>
