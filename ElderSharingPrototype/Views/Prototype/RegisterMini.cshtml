@model ElderSharingPrototype.Models.MiniRegisterViewModel
@{
    ViewData["Title"] = "פרטים בסיסיים";
    var level = (string)(ViewBag.Level ?? "A");

    string levelText = level == "A" ? "רמה 1 – פרטיות גבוהה" :
                       level == "B" ? "רמה 2 – שיתוף בינוני" :
                                      "רמה 3 – שיתוף גבוה";
}

<div class="container py-4" style="max-width: 900px;">
    <h1 class="mb-2">פרטים בסיסיים</h1>
    <p class="text-muted mb-4">רמת השיתוף שנבחרה: <strong>@levelText</strong></p>

    <div class="alert alert-info">
        נבקש רק את הפרטים הנחוצים לרמה שבחרת (לפי המקרא במסך הפתיח).
        <br />
        אפשר לשנות רמת שיתוף בכל רגע.
    </div>

    <form method="post" class="mt-4">
        <div class="row g-3">

            <!-- רמה A: שם, גיל, אזור -->
            <div class="col-12 col-md-4">
                <label class="form-label">שם פרטי</label>
                <input asp-for="FirstName" class="form-control form-control-lg" placeholder="לדוגמה: דינה" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">גיל</label>
                <input asp-for="Age" type="number" class="form-control form-control-lg" placeholder="לדוגמה: 72" />
                <span asp-validation-for="Age" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">אזור מגורים</label>
                <select asp-for="Area" class="form-select form-select-lg">
                    <option value="">בחר/י</option>
                    <option value="צפון">צפון</option>
                    <option value="מרכז">מרכז</option>
                    <option value="דרום">דרום</option>
                    <option value="ירושלים">ירושלים</option>
                    <option value="שרון">שרון</option>
                </select>
                <span asp-validation-for="Area" class="text-danger"></span>
            </div>

            @if (level == "B" || level == "C")
            {
                <hr class="my-3" />

                <!-- רמה B: קופ"ח + תרופות -->
                <div class="col-12 col-md-6">
                    <label class="form-label">קופת חולים</label>
                    <select asp-for="Hmo" class="form-select form-select-lg">
                        <option value="">בחר/י</option>
                        <option value="כללית">כללית</option>
                        <option value="מכבי">מכבי</option>
                        <option value="מאוחדת">מאוחדת</option>
                        <option value="לאומית">לאומית</option>
                    </select>
                    <span asp-validation-for="Hmo" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">תרופות (אופציונלי)</label>
                    <input asp-for="Medications" class="form-control form-control-lg"
                           placeholder="לדוגמה: אקמול, ויטמין D" />
                </div>
            }

            @if (level == "C")
            {
                <hr class="my-3" />

                <!-- רמה C: איש קשר לחירום -->
                <div class="col-12 col-md-6">
                    <label class="form-label">שם איש קשר לחירום</label>
                    <input asp-for="EmergencyContactName" class="form-control form-control-lg" placeholder="לדוגמה: יוסי" />
                    <span asp-validation-for="EmergencyContactName" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">טלפון איש קשר לחירום</label>
                    <input asp-for="EmergencyContactPhone" class="form-control form-control-lg" placeholder="לדוגמה: 050-1234567" />
                    <span asp-validation-for="EmergencyContactPhone" class="text-danger"></span>
                </div>

                <hr class="my-3" />

                <!-- רמה C: אשראי -->
                <div class="alert alert-warning">
                    פרטי אשראי נדרשים לצורך שירותי בנק (דמו).
                    <br />
                    מומלץ להזין רק נתונים לדוגמה לצורך המחקר.
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">4 ספרות אחרונות של כרטיס אשראי</label>
                    <input asp-for="CreditCardLast4" class="form-control form-control-lg"
                           maxlength="4" placeholder="לדוגמה: 1234" />
                    <span asp-validation-for="CreditCardLast4" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">תוקף כרטיס (MM/YY)</label>
                    <input asp-for="CreditCardExpiry" class="form-control form-control-lg"
                           placeholder="לדוגמה: 08/27" />
                    <span asp-validation-for="CreditCardExpiry" class="text-danger"></span>
                </div>
            }
        </div>

        <div class="d-grid mt-4">
            <button class="btn btn-primary btn-lg" type="submit">המשך לשירותים</button>
        </div>

        <div class="mt-3">
            <a class="btn btn-link" href="/Prototype/Choose">חזרה לבחירת רמה</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
