    public class ServiceItemVm
    {
        public string Title { get; set; } = "";
        public string Desc { get; set; } = "";
        public string Href { get; set; } = "";
        public int RequiredLevelOrder { get; set; }
        public int OriginLevelOrder { get; set; }
    }

    public class ServiceCategoryVm
    {
        public string Key { get; set; } = "";
        public string Title { get; set; } = "";
        public string Emoji { get; set; } = "";
        public List<ServiceItemVm> Services { get; set; } = new();
    }

    public string GetLevelHeaderHtml(int level, bool isAdapted, string level1IconColor, string level2IconColor, string level3IconColor)
    {
        string title = level == 1 ? "רמה 1 – פרטיות גבוהה"
                     : level == 2 ? "רמה 2 – שיתוף בינוני"
                     : "רמה 3 – שיתוף גבוה";

        string cssClass = level == 1 ? "level-header-card level-header-level1"
                        : level == 2 ? "level-header-card level-header-level2"
                        : "level-header-card level-header-level3";

        if (!isAdapted)
        {
            return $"<div class='{cssClass}'>{title}</div>";
        }

        string iconHtml = level == 1
            ? PrivacyIcon(level1IconColor).ToString()
            : level == 2
                ? SharingIcon140(level2IconColor).ToString()
                : SelfDisplayIcon95(level3IconColor).ToString();

        return $@"<div class='{cssClass}'>
                    <span class='level-header-icon'>{iconHtml}</span>
                    <span>{title}</span>
                  </div>";
    }

public IHtmlContent RenderServiceBox(ServiceItemVm service, bool allowed, string btnStyleInline, bool withExplanation, bool isAdapted, string level1IconColor, string level2IconColor, string level3IconColor)
{
    string badgeClass = service.OriginLevelOrder == 1 ? "service-level-badge level-badge-1"
                      : service.OriginLevelOrder == 2 ? "service-level-badge level-badge-2"
                      : "service-level-badge level-badge-3";

    string iconHtml;

    if (!isAdapted)
    {
        iconHtml = service.OriginLevelOrder == 1 ? "🔒"
                 : service.OriginLevelOrder == 2 ? "🔗"
                 : "🛡️";
    }
    else
    {
        iconHtml = service.OriginLevelOrder == 1
            ? PrivacyIcon(level1IconColor).ToString()
            : service.OriginLevelOrder == 2
                ? SharingIcon140(level2IconColor).ToString()
                : SelfDisplayIcon95(level3IconColor).ToString();
    }

    var badge = $@"
<span class='{badgeClass}'>
    <span class='service-level-badge-icon'>{iconHtml}</span>
    <span>רמה {service.OriginLevelOrder}</span>
</span>";

    var descHtml = (!string.IsNullOrWhiteSpace(service.Desc) && withExplanation)
        ? $"<div class='service-item-desc'>{service.Desc}</div>"
        : "";

    var actionHtml = allowed
        ? $"<a class='btn btn-primary w-100 btn-lg' style='{btnStyleInline}' href='{service.Href}'>פתח שירות</a>"
        : $"<button type='button' class='btn btn-outline-secondary w-100 btn-lg' style='{btnStyleInline}' onclick=\"openUpgradeModal('{service.Title}')\">שירות חסום</button>";

    var html = $@"
        <div class='service-item-box'>
            <div>
                {badge}
                <div class='service-item-title'>{service.Title}</div>
                {descHtml}
            </div>
            <div class='service-btn-wrap'>
                {actionHtml}
            </div>
        </div>";

    return new HtmlString(html);
}
}