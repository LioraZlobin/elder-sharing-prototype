@using Microsoft.AspNetCore.Html

@{
    ViewData["Title"] = "שירותים רפואיים";
    var level = (string)(ViewBag.Level ?? "A"); // A / B / C
    string levelText = level == "A" ? "רמה 1 – פרטיות גבוהה" :
                       level == "B" ? "רמה 2 – שיתוף בינוני" :
                                      "רמה 3 – שיתוף גבוה";
}

<div class="container py-4" style="max-width: 1100px;">

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="mb-2">שירותים רפואיים</h1>
            <p class="text-muted mb-0" style="font-size:18px;">
                רמת השיתוף שנבחרה: <strong>@levelText</strong>
            </p>
        </div>

        <a class="btn btn-outline-primary btn-lg" href="/Prototype/Choose" style="font-size:18px;">
            שינוי רמת שיתוף
        </a>
    </div>

    <div class="d-flex gap-2 flex-wrap mt-3">
        @* לא מציגים ברמה C *@
        @if (level != "C")
        {
            <a class="btn btn-primary btn-lg" style="font-size:18px;" href="/Prototype/Choose">
                רוצה להוסיף עוד שירותים?
            </a>
        }

        <form method="post" action="/Prototype/DeleteMyData" class="m-0">
            <button type="submit" class="btn btn-outline-danger btn-lg" style="font-size:20px;">
                מחיקת כל המידע שלי
            </button>
        </form>
    </div>

    <hr class="my-4" />

    <div class="row g-3">

        <!-- תזכורות תרופות: כרטיס אחד שמתאים לרמה -->
        @if (level == "A")
        {
            @ServiceCard(
            "תזכורת לתרופות",
                "תזכורת כללית ללקיחת תרופות.",
                "💊",
                true,
                "/Health/MedicationReminders"
                )
                }

        @if (level == "B" || level == "C")
        {
            @ServiceCard(
            "תזכורות תרופות עם שם תרופה",
                "התראות לתרופות לפי שם ושעה.",
                "💊",
                true,
                "/Health/MedicationReminders"
                )
                }


        @ServiceCard(
                "תזכורת ללקיחת מדדים",
                "תזכורת למדדים: לחץ דם, סוכר.",
                "🩺",
                true,
                "/Health/VitalsReminders"
                )

        <!-- שירותים לרמה B ומעלה -->
        @{
                bool levelBAllowed = (level == "B" || level == "C");
                }

        @ServiceCard(
                "ניהול רשימת תרופות קבועות",
                "צפייה/עדכון ברשימת התרופות הקבועות.",
                "📋",
                levelBAllowed,
                levelBAllowed ? "/Health/MedicationList" : "#"
                )

        <!-- שירותים לרמה C בלבד -->
        @{
            bool levelCAllowed = (level == "C");
        }

        @ServiceCard(
        "הזנת מדידות ושמירה",
                "הזנת לחץ דם/סוכר ושמירה למעקב (דמו).",
                "📈",
                levelCAllowed,
                levelCAllowed ? "/Health/Measurements" : "#"
                )

        @ServiceCard(
                "זימון תור לרופא",
                "קביעת תור לרופא (דמו).",
                "🏥",
                levelCAllowed,
                levelCAllowed ? "/Health/AppointmentRequest" : "#"
                )

    </div>

<!-- Modal לשדרוג רמת שיתוף (לשירותים חסומים) -->
<div class="modal fade" id="upgradeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">נדרשת רמת שיתוף גבוהה יותר</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="סגור"></button>
            </div>
            <div class="modal-body" style="font-size:18px;">
                כדי להשתמש בשירות <strong id="blockedServiceName"></strong> נדרשת רמת שיתוף גבוהה יותר.
                <br />
                האם תרצה לשדרג?
            </div>
            <div class="modal-footer">
                <form method="post" action="/Prototype/UpgradeLevel" class="m-0">
                    <button type="submit" class="btn btn-primary btn-lg">כן, שדרג</button>
                </form>
                <button type="button" class="btn btn-outline-secondary btn-lg" data-bs-dismiss="modal">
                    לא, השאר
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openUpgradeModal(serviceName) {
        document.getElementById('blockedServiceName').innerText = serviceName;

        const modalEl = document.getElementById('upgradeModal');
        const modal = new bootstrap.Modal(modalEl);
        modal.show();
    }
</script>
}

@functions {
    public IHtmlContent ServiceCard(string title, string desc, string icon, bool allowed, string href)
    {
        var btnText = allowed ? "פתח שירות" : "שירות חסום";
        var btnClass = allowed ? "btn btn-primary w-100 btn-lg" : "btn btn-outline-secondary w-100 btn-lg";

        var action = allowed
            ? $"<a class='{btnClass}' href='{href}'>" + btnText + "</a>"
            : $"<button type='button' class='{btnClass}' onclick=\"openUpgradeModal('{title}')\">" + btnText + "</button>";

        var html = $@"
<div class='col-12 col-md-6 col-lg-4'>
  <div class='card h-100 shadow-sm'>
    <div class='card-body d-flex flex-column'>
      <div class='d-flex align-items-center gap-2 mb-2'>
        <div style='font-size: 1.8rem;'>{icon}</div>
        <h2 class='h5 mb-0'>{title}</h2>
      </div>
      <p class='text-muted mb-4' style='font-size:18px;'>{desc}</p>
      <div class='mt-auto'>{action}</div>
    </div>
  </div>
</div>";
        return new HtmlString(html);
    }
}
