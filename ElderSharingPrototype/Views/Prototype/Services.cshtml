@using System.Linq
@using Microsoft.AspNetCore.Html
@using ElderSharingPrototype.Models

@{
    ViewData["Title"] = "שירותים רפואיים";

    var level = (string)(ViewBag.Level ?? "A"); // A / B / C
    string levelText = level == "A" ? "רמה 1 – פרטיות גבוהה" :
                       level == "B" ? "רמה 2 – שיתוף בינוני" :
                                      "רמה 3 – שיתוף גבוה";

    var explanationMode = (ExplanationMode)(ViewBag.ExplanationMode ?? (int)ExplanationMode.WithExplanation);
    var uiAdaptation = (UiAdaptation)(ViewBag.UiAdaptation ?? (int)UiAdaptation.NotAdapted);

    bool isAdapted = uiAdaptation == UiAdaptation.Adapted;
    bool withExplanation = explanationMode == ExplanationMode.WithExplanation;

    var titleStyle = isAdapted ? "font-size:46px; line-height:1.2;" : "font-size:30px; line-height:1.2;";
    var textStyle = isAdapted ? "font-size:22px; line-height:1.7;" : "font-size:16px; line-height:1.5;";
    var btnStyle = isAdapted ? "font-size:24px; padding:16px 22px;" : "font-size:18px; padding:10px 14px;";
    var dangerBtnStyle = isAdapted ? "font-size:26px; padding:16px 22px;" : "font-size:20px; padding:10px 14px;";

    Func<string, string> MaybeDesc = (d) => withExplanation ? d : "";

    int currentLevelOrder = level == "A" ? 1 : level == "B" ? 2 : 3;

    // ===== ROBOT UI =====
    string robotLine = level == "A"
        ? "בחרתי עבורך שירות פתוח מתוך רמה 1."
        : level == "B"
            ? "בחרתי עבורך שירות פתוח מתוך רמה 1 או רמה 2."
            : "בחרתי עבורך שירות פתוח מתוך כל הרמות הזמינות לך.";

    var recText = ViewBag.RobotRecText as string;
    var recUrl = ViewBag.RobotRecUrl as string;
    var recAudio = ViewBag.RobotRecAudio as string;
    var recBtnText = ViewBag.RobotRecButtonText as string;

    var hasRec = !string.IsNullOrWhiteSpace(recText)
                 && !string.IsNullOrWhiteSpace(recUrl)
                 && !string.IsNullOrWhiteSpace(recAudio);

    string robotTip = hasRec ? recText! : "המלצה שלי עכשיו: תזכורת למדדים.";
    string primaryHref = hasRec ? recUrl! : "/Health/VitalsReminders";
    string primaryTitle = "השירות שנבחר עבורך";
    string primaryBtnText = !string.IsNullOrWhiteSpace(recBtnText) ? recBtnText! : "פתחי שירות";
    string recommendedActionLabel = hasRec ? recText! : "תזכורת ללקיחת מדדים";

    // אותם צבעים כמו ב-Intro
    var level1Bg = "#fde7ea";
    var level1Border = "#f6b7c0";
    var level1IconColor = "#e53935";

    var level2Bg = "#e7f1ff";
    var level2Border = "#b3d4ff";
    var level2IconColor = "#1e88e5";

    var level3Bg = "#e9f7ef";
    var level3Border = "#b7e4c7";
    var level3IconColor = "#43a047";

    var categories = new List<ServiceCategoryVm>
    {
        new ServiceCategoryVm
        {
            Key = "meds",
            Title = "תרופות",
            Emoji = "💊",
            Services = new List<ServiceItemVm>
            {
                new ServiceItemVm
                {
                    Title = "תזכורת כללית לנטילת תרופות",
                    Desc = MaybeDesc("תזכורת כללית ללא שם תרופה."),
                    Href = "/Health/MedicationReminders?mode=basic",
                    RequiredLevelOrder = 1,
                    OriginLevelOrder = 1
                },
                new ServiceItemVm
                {
                    Title = "ניהול תרופות ותזכורות",
                    Desc = MaybeDesc("ניהול רשימת תרופות קבועות והוספת תזכורות לפי שם התרופה."),
                    Href = "/Health/MedicationReminders?mode=detailed",
                    RequiredLevelOrder = 2,
                    OriginLevelOrder = 2
                },
                 new ServiceItemVm
                {
                    Title = "עדכון מלאי וקשר עם בית המרקחת",
                    Desc = MaybeDesc("בדיקת מלאי תרופות וקשר ישיר עם סניף בית מרקחת."),
                    Href = "/Health/PharmacyContact",
                    RequiredLevelOrder = 3,
                    OriginLevelOrder = 3
                }
            }
        },
        new ServiceCategoryVm
        {
            Key = "vitals",
            Title = "מדדים רפואיים",
            Emoji = "🩺",
            Services = new List<ServiceItemVm>
            {
                new ServiceItemVm
                {
                    Title = "תזכורת ללקיחת מדדים",
                    Desc = MaybeDesc("תזכורת למדדים כמו לחץ דם, סוכר ודופק."),
                    Href = "/Health/VitalsReminders",
                    RequiredLevelOrder = 1,
                    OriginLevelOrder = 1
                },
                new ServiceItemVm
                {
                    Title = "מדידת מדדים חד־פעמית",
                    Desc = MaybeDesc("מדידה חד־פעמית של מדדים רפואיים."),
                    Href = "/Health/Measurements?mode=onetime",
                    RequiredLevelOrder = 2,
                    OriginLevelOrder = 2
                },
                new ServiceItemVm
                {
                    Title = "מדידת מדדים ושמירת היסטוריה",
                    Desc = MaybeDesc("מדידת מדדים עם שמירה להיסטוריה אישית."),
                    Href = "/Health/Measurements?mode=history",
                    RequiredLevelOrder = 3,
                    OriginLevelOrder = 3
                }
            }
        },
        new ServiceCategoryVm
        {
            Key = "doctor",
            Title = "רופא / קופת חולים",
            Emoji = "🏥",
            Services = new List<ServiceItemVm>
            {
                new ServiceItemVm
                {
                    Title = "המלצה לביקור אצל רופא",
                    Desc = MaybeDesc("המלצה כללית לביקור אצל רופא או ביצוע בדיקות שגרתיות."),
                    Href = "/Health/CheckupRecommendations",
                    RequiredLevelOrder = 1,
                    OriginLevelOrder = 1
                },
                new ServiceItemVm
                {
                    Title = "זימון תור לרופא",
                    Desc = MaybeDesc("בקשת תור לרופא לפי תחום טיפול."),
                    Href = "/Health/AppointmentRequest",
                    RequiredLevelOrder = 2,
                    OriginLevelOrder = 2
                },
                new ServiceItemVm
                {
                    Title = "תור טלפוני / וידאו לרופא",
                    Desc = MaybeDesc("שיחה טלפונית או וידאו עם רופא (דמו)."),
                    Href = "/Health/TeleVisit",
                    RequiredLevelOrder = 3,
                    OriginLevelOrder = 3
                }
            }
        },
        new ServiceCategoryVm
        {
            Key = "audio",
            Title = "התראות / קשר בחירום",
            Emoji = "🔊",
            Services = new List<ServiceItemVm>
            {
                new ServiceItemVm
                {
                    Title = "התרעה קולית במצבי חריגה",
                    Desc = MaybeDesc("התראה קולית במקרה של חריגה או סיכון סביבתי."),
                    Href = "/Health/AudioAlerts",
                    RequiredLevelOrder = 1,
                    OriginLevelOrder = 1
                },
                new ServiceItemVm
                {
                    Title = "איש קשר והודעת חירום",
                    Desc = MaybeDesc("שמירת פרטי איש קשר לחירום וכתיבת הודעת טקסט במקרה חירום."),
                    Href = "/Health/EmergencyContact",
                    RequiredLevelOrder = 2,
                    OriginLevelOrder = 2
                },
                new ServiceItemVm
                {
                    Title = "יצירת קשר חזותי במקרה חירום",
                    Desc = MaybeDesc("יצירת קשר חזותי עם איש קשר במקרה חירום."),
                    Href = "/Health/EmergencyVideo",
                    RequiredLevelOrder = 3,
                    OriginLevelOrder = 3
                }
            }
        }
    };

    var futureLevel2Categories = categories
        .Select(c => new ServiceCategoryVm
        {
            Key = c.Key,
            Title = c.Title,
            Emoji = c.Emoji,
            Services = c.Services.Where(s => s.RequiredLevelOrder == 2).ToList()
        })
        .ToList();

    var futureLevel3Categories = categories
        .Select(c => new ServiceCategoryVm
        {
            Key = c.Key,
            Title = c.Title,
            Emoji = c.Emoji,
            Services = c.Services.Where(s => s.RequiredLevelOrder == 3).ToList()
        })
        .ToList();

    bool showExtraServicesAccordion = currentLevelOrder < 3;
}

<style>
    .services-board-title {
        font-weight: 800;
        margin-bottom: 18px;
    }

    .level-section-title {
        margin-bottom: 20px;
    }

    .level-header-card {
        position: relative;
        border-radius: 18px;
        padding: 18px 86px 18px 22px;
        border: 2px solid;
        min-height: 88px;
        display: flex;
        align-items: center;
        font-weight: 800;
        font-size: 28px;
        line-height: 1.35;
    }

    .level-header-icon {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 56px;
        height: 56px;
    }

    .level-header-level1 {
        background: #fde7ea;
        border-color: #f6b7c0;
    }

    .level-header-level2 {
        background: #e7f1ff;
        border-color: #b3d4ff;
    }

    .level-header-level3 {
        background: #e9f7ef;
        border-color: #b7e4c7;
    }

    .service-category-col {
        display: flex;
    }

    .service-category-card {
        width: 100%;
        border-radius: 24px;
        border: 1px solid rgba(15,23,42,0.08);
        background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,251,255,0.98) 100%);
        box-shadow: 0 10px 30px rgba(15,23,42,0.08);
        padding: 22px 18px 18px;
        display: flex;
        flex-direction: column;
        min-height: 100%;
    }

    .service-category-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 120px;
        margin-bottom: 14px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(15,23,42,0.07);
    }

    .service-category-emoji {
        font-size: 42px;
        line-height: 1;
        margin-bottom: 10px;
    }

    .service-category-name {
        text-align: center;
        font-weight: 800;
        font-size: 22px;
        line-height: 1.35;
        min-height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .service-items-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
        flex: 1;
    }

    .service-item-box {
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 20px;
        background: #fff;
        padding: 16px;
        min-height: 250px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 4px 12px rgba(15,23,42,0.04);
    }

.service-level-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 6px 12px 6px 10px;
    font-size: 14px;
    font-weight: 700;
    width: fit-content;
    margin-bottom: 12px;
    border: 1px solid transparent;
    line-height: 1;
}

.service-level-badge-icon {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 22px;
}

.service-level-badge-icon svg {
    width: 100%;
    height: 100%;
    display: block;
}

.service-level-badge.level-badge-1 {
    background: #fde7ea;
    border-color: #f6b7c0;
    color: #7a1f28;
}

.service-level-badge.level-badge-2 {
    background: #e7f1ff;
    border-color: #b3d4ff;
    color: #0b5fc1;
}

.service-level-badge.level-badge-3 {
    background: #e9f7ef;
    border-color: #b7e4c7;
    color: #2e7d32;
}

    .service-item-title {
        font-weight: 800;
        font-size: 20px;
        line-height: 1.4;
        margin-bottom: 10px;
        min-height: 56px;
    }

    .service-item-desc {
        color: #6c757d;
        font-size: 17px;
        line-height: 1.6;
        margin-bottom: 16px;
        flex: 1;
    }

    .service-btn-wrap {
        margin-top: auto;
    }

    .empty-category-box {
        min-height: 120px;
        border: 1px dashed rgba(108,117,125,0.35);
        border-radius: 18px;
        background: #fafafa;
        color: #6c757d;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 16px;
        font-size: 16px;
        line-height: 1.5;
    }

    .extra-services-shell {
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid rgba(15,23,42,0.08);
        box-shadow: 0 10px 24px rgba(15,23,42,0.08);
        background: #fff;
    }

    .extra-services-btn {
        width: 100%;
        text-align: right;
        font-weight: 800;
        background: #fff;
        border: none;
        padding: 18px 22px;
        font-size: 22px;
    }

    .locked-level-title {
        margin-bottom: 18px;
    }

    .section-divider {
        height: 1px;
        background: rgba(15,23,42,0.08);
        margin: 28px 0;
    }

    @@media (max-width: 1199.98px) {
        .service-item-box {
            min-height: 230px;
        }
    }

    @@media (max-width: 767.98px) {
        .level-header-card {
            font-size: 22px;
            padding: 16px 72px 16px 18px;
        }

        .level-header-icon {
            width: 46px;
            height: 46px;
            top: 12px;
            right: 12px;
        }

        .service-category-emoji {
            font-size: 36px;
        }

        .service-category-name {
            font-size: 20px;
            min-height: auto;
        }

        .service-item-title {
            font-size: 18px;
            min-height: auto;
        }

        .service-item-box {
            min-height: auto;
        }

        .extra-services-btn {
            font-size: 18px;
        }
    }
</style>

<div class="container py-4" style="max-width: 1380px;">

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1 class="mb-2" style="@titleStyle">שירותים רפואיים</h1>

            @if (withExplanation)
            {
                <p class="text-muted mb-0" style="@textStyle">
                    רמת השיתוף שנבחרה: <strong>@levelText</strong>
                </p>
            }
        </div>

        <a class="btn btn-outline-primary btn-lg" href="/Prototype/Choose" style="@btnStyle">
            שינוי רמת שיתוף
        </a>
    </div>

    <div class="d-flex gap-2 flex-wrap mt-3">
        @if (level != "C")
        {
            <a class="btn btn-primary btn-lg" style="@btnStyle" href="/Prototype/Choose">
                רוצה להוסיף עוד שירותים?
            </a>
        }

        <form method="post" action="/Prototype/DeleteMyData" class="m-0">
            <button type="submit" class="btn btn-outline-danger btn-lg" style="@dangerBtnStyle">
                מחיקת כל המידע שלי
            </button>
        </form>
    </div>

    <hr class="my-4" />

    @if (isAdapted)
    {
        <div class="mb-4 p-4" style="border-radius:18px; border:1px solid rgba(15,23,42,0.08); background: rgba(255,255,255,0.88); box-shadow: 0 10px 24px rgba(15,23,42,0.08);">
            <div class="d-flex align-items-start gap-3">
                <div style="font-size:44px; line-height:1;">🤖</div>

                <div class="robot-face">
                    <span class="robot-wave"></span>
                </div>

                <div style="@textStyle">
                    <div style="font-weight:800; font-size:26px; margin-bottom:6px;">הרובוט אומר:</div>
                    <div class="mb-2">@robotLine</div>
                    <div style="font-weight:700;">@robotTip</div>

                    <div class="d-flex gap-2 mt-2">
                        <button id="robotReplayBtn" type="button" class="btn btn-outline-primary btn-sm" onclick="robotSpeak()">🔊 השמע שוב</button>
                        <button id="robotStopBtn" type="button" class="btn btn-outline-secondary btn-sm" onclick="robotStop()">⏹ עצור</button>
                    </div>
                </div>
            </div>

            <div class="mt-3 p-3" style="border-radius:16px; background: rgba(230,241,255,0.85); border: 1px solid rgba(37,140,251,0.25);">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div style="font-size:22px; font-weight:800;">
                        🤖 @primaryTitle
                    </div>
                    <a class="btn btn-primary btn-lg" href="@primaryHref" style="@btnStyle">
                        @primaryBtnText
                    </a>
                </div>
                <div class="text-muted mt-2" style="font-size:18px;">
                    פעולה מומלצת: <strong>@recommendedActionLabel</strong>
                </div>
            </div>
        </div>
    }

    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <h2 class="services-board-title m-0" style="font-size:30px;">השירותים שלי</h2>
    <span class="text-muted" style="@textStyle">השירותים הפתוחים עבורך, מסודרים לפי נושאים</span>
</div>

@{
    var visibleCategories = categories
        .Select(c => new ServiceCategoryVm
        {
            Key = c.Key,
            Title = c.Title,
            Emoji = c.Emoji,
            Services = c.Services.Where(s => s.RequiredLevelOrder <= currentLevelOrder).ToList()
        })
        .ToList();
}

<div class="row g-4">
    @foreach (var category in visibleCategories)
    {
        <div class="col-12 col-md-6 col-xl-3 service-category-col">
            <div class="service-category-card">
                <div class="service-category-header">
                    <div class="service-category-emoji">@category.Emoji</div>
                    <div class="service-category-name">@category.Title</div>
                </div>

                <div class="service-items-list">
                    @if (category.Services.Any())
                    {
                        @foreach (var service in category.Services)
                        {
                            @RenderServiceBox(service, true, btnStyle, withExplanation, isAdapted, level1IconColor, level2IconColor, level3IconColor)
                        }
                    }
                    else
                    {
                        <div class="empty-category-box">
                            אין שירות פתוח בקטגוריה זו
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

    @if (showExtraServicesAccordion)
    {
        <div class="mt-5">
            <div class="extra-services-shell">
                <button class="extra-services-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#extraServicesCollapse" aria-expanded="false" aria-controls="extraServicesCollapse">
                    שירותים נוספים
                </button>

                <div id="extraServicesCollapse" class="collapse">
                    <div class="p-4 p-md-5" style="background:#fff;">
                        @if (currentLevelOrder == 1)
                        {
                            <div class="locked-level-title">
                                @Html.Raw(GetLevelHeaderHtml(2, isAdapted, level1IconColor, level2IconColor, level3IconColor))
                            </div>

                            <div class="row g-4">
                                @foreach (var category in futureLevel2Categories)
                                {
                                    <div class="col-12 col-md-6 col-xl-3 service-category-col">
                                        <div class="service-category-card">
                                            <div class="service-category-header">
                                                <div class="service-category-emoji">@category.Emoji</div>
                                                <div class="service-category-name">@category.Title</div>
                                            </div>

                                            <div class="service-items-list">
                                                @if (category.Services.Any())
                                                {
                                                    @foreach (var service in category.Services)
                                                    {
                                                        @RenderServiceBox(service, false, btnStyle, withExplanation, isAdapted, level1IconColor, level2IconColor, level3IconColor)
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="text-muted text-center">אין שירות נוסף בקטגוריה זו ברמה 2</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="section-divider"></div>

                            <div class="locked-level-title">
                                @Html.Raw(GetLevelHeaderHtml(3, isAdapted, level1IconColor, level2IconColor, level3IconColor))
                            </div>

                            <div class="row g-4">
                                @foreach (var category in futureLevel3Categories)
                                {
                                    <div class="col-12 col-md-6 col-xl-3 service-category-col">
                                        <div class="service-category-card">
                                            <div class="service-category-header">
                                                <div class="service-category-emoji">@category.Emoji</div>
                                                <div class="service-category-name">@category.Title</div>
                                            </div>

                                            <div class="service-items-list">
                                                @if (category.Services.Any())
                                                {
                                                    @foreach (var service in category.Services)
                                                    {
                                                        @RenderServiceBox(service, false, btnStyle, withExplanation, isAdapted, level1IconColor, level2IconColor, level3IconColor)
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="text-muted text-center">אין שירות נוסף בקטגוריה זו ברמה 3</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else if (currentLevelOrder == 2)
                        {
                            <div class="locked-level-title">
                                @Html.Raw(GetLevelHeaderHtml(3, isAdapted, level1IconColor, level2IconColor, level3IconColor))
                            </div>

                            <div class="row g-4">
                                @foreach (var category in futureLevel3Categories)
                                {
                                    <div class="col-12 col-md-6 col-xl-3 service-category-col">
                                        <div class="service-category-card">
                                            <div class="service-category-header">
                                                <div class="service-category-emoji">@category.Emoji</div>
                                                <div class="service-category-name">@category.Title</div>
                                            </div>

                                            <div class="service-items-list">
                                                @if (category.Services.Any())
                                                {
                                                    @foreach (var service in category.Services)
                                                    {
                                                        @RenderServiceBox(service, false, btnStyle, withExplanation, isAdapted, level1IconColor, level2IconColor, level3IconColor)
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="text-muted text-center">אין שירות נוסף בקטגוריה זו ברמה 3</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="modal fade" id="upgradeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" style="@textStyle">נדרשת רמת שיתוף גבוהה יותר</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="סגור"></button>
                </div>

                <div class="modal-body" style="@textStyle">
                    כדי להשתמש בשירות <strong id="blockedServiceName"></strong> נדרשת רמת שיתוף גבוהה יותר.
                    <br />
                    האם תרצה לשדרג?
                </div>

                <div class="modal-footer">
                    <form method="post" action="/Prototype/UpgradeLevel" class="m-0">
                        <button type="submit" class="btn btn-primary btn-lg" style="@btnStyle">כן, שדרג</button>
                    </form>
                    <button type="button" class="btn btn-outline-secondary btn-lg" style="@btnStyle" data-bs-dismiss="modal">
                        לא, השאר
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    (function () {
        const style = document.createElement("style");
        style.innerHTML = `
            .modal-backdrop { z-index: 1040 !important; }
            .modal { z-index: 1055 !important; }
            .modal-dialog, .modal-content { pointer-events: auto !important; }
        `;
        document.head.appendChild(style);
    })();

    function openUpgradeModal(serviceName) {
        document.getElementById('blockedServiceName').innerText = serviceName;
        const modalEl = document.getElementById('upgradeModal');
        const modal = new bootstrap.Modal(modalEl);
        modal.show();
    }

    (function () {
        const isAdapted = @( (uiAdaptation == UiAdaptation.Adapted) ? "true" : "false" );
        if (!isAdapted) return;

        const level = "@level";
        const recText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((string)(ViewBag.RobotRecText ?? "")));
        const recAudioFile = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((string)(ViewBag.RobotRecAudio ?? "")));

        const fallbackByLevel = {
            A: "/audio/robot/medication_basic.mp3",
            B: "/audio/robot/medication_management.mp3",
            C: "/audio/robot/pharmacy_contact.mp3"
        };

        const replayBtn = document.getElementById("robotReplayBtn");
        const stopBtn = document.getElementById("robotStopBtn");
        const robotBox = document.querySelector(".robot-face")?.parentElement;
        let audio = null;

        function pickAudioSrc() {
            const lvl = (level || "A").trim().toUpperCase();
            const file = (recAudioFile || "").trim();

            if (file) return "/audio/robot/" + file;
            return fallbackByLevel[lvl] || fallbackByLevel.A;
        }

        function stopAudio() {
            if (!audio) return;
            try {
                audio.pause();
                audio.currentTime = 0;
            } catch (e) {}
            robotBox?.classList.remove("robot-speaking");
        }

        function playAudio() {
            if (!recText && !recAudioFile) return;

            stopAudio();

            const src = pickAudioSrc();
            audio = new Audio(src);

            audio.onplay = () => robotBox?.classList.add("robot-speaking");
            audio.onended = () => robotBox?.classList.remove("robot-speaking");
            audio.onerror = () => robotBox?.classList.remove("robot-speaking");

            audio.play().catch(() => {});
        }

        window.robotSpeak = playAudio;
        window.robotStop = stopAudio;

        if (replayBtn) replayBtn.addEventListener("click", playAudio);
        if (stopBtn) stopBtn.addEventListener("click", stopAudio);

        window.addEventListener("load", () => {
            setTimeout(playAudio, 250);
        });
    })();
</script>
}

